---
import TimelineExhibit from "../components/TimelineExhibit.jsx";
import Quiz from "../components/Quiz.jsx";
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>Evolution of Computing in the Philippines</title>
  </head>

  <body>
    <TimelineExhibit client:only="react" />

      <!-- Quiz Section -->
      <section class="mt-16 pb-8">
        <h2 class="text-4xl font-bold text-center mb-3 text-white">
          Philippine Computing Knowledge Challenge
        </h2>

        <p class="text-center text-gray-300 mb-8">
          Test your knowledge of Philippine computing history after exploring the interactive timeline.
        </p>

        <Quiz client:only="react" />
      </section>
  
  </body>
</html>
