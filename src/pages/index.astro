---
import TimelineExhibit from "../components/TimelineExhibit.jsx";
import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>Evolution of Computing in the Philippines</title>
  </head>

  <body>
    <TimelineExhibit client:only="react" />

    <section class="text-center py-16">

      <h2 class="text-4xl font-bold text-white mb-4">
        Ready for the Museum Challenge?
      </h2>

      <p class="text-gray-300 mb-8 text-lg">
        Explore the interactive timeline first, then see how much you've learned!
      </p>

      <a
        href="/CSARCH2-Group-6/quiz"
        class="inline-block bg-cyan-600 hover:bg-cyan-700 text-white px-8 py-4 rounded-xl text-xl font-semibold transition shadow-lg"
      >
        🧠 Take the Museum Challenge
      </a>

    </section>

      
  
  </body>
</html>
